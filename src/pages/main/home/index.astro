---
import Layout from "../../../layouts/Layout.astro"
---

<Layout title="Circuit Surfers">
    <main>
        <section class="hero">
            <div class="hero-content">
                <h1 class="circuit"><span class="accent">CIRCUIT</span> SURFERS</h1>
            </div>
        </section>
        <section id="about">
            <h1>About Us</h1>
            <p>Circuit Surfers is an independent high school VEX V5 robotics team based in Fremont, California. We are a passionate group of student engineers, programmers, and designers dedicated to pushing the boundaries of competitive robotics. Competing in the VEX V5 Robotics Competition, we combine technical expertise with creative problem-solving to design, build, and program robots capable of taking on the world's best teams. Our mission is to foster a love for STEM, develop real-world engineering skills, and represent our community on the competitive stage.</p>
        </section>
        <section id="team">
            <h1>Team</h1>
            <p>Our team members for the 2026-2027 season.</p>
        </section>
    </main>
</Layout>

<style>
    main {
        padding-top: 0;
        margin: 0;
        gap: 10rem;
    }

    .hero {
        width: 100%;
        height: 100vh;
        background-color: var(--rgb-bg-from);
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-sizing: border-box;
        padding-top: 95px;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
        width: 100%;
    }

    .circuit {
        font-size: clamp(2rem, 6vw, 5rem);
        white-space: nowrap;
        font-weight: 900;
        color: white;
        text-transform: uppercase;
        margin: 0;
        letter-spacing: 2px;
    }

    #about, #team {
        background: var(--rgb-code-bg);
        padding: 4rem 2rem 1.5rem 2rem;
        margin: 0 auto 0 auto;
        max-width: 1400px;
        border: 2px solid var(--rgb-accent-from);
        border-radius: 16px;
        scroll-margin-top: 105px;
        box-sizing: border-box;
    }

    #about p, #team p {
        margin-top: 1.5rem;
        text-align: left;
        line-height: 2;
        max-width: 600px;
    }

    .accent {
        color: #38b6ff;
    }
</style>