---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Donate">
    <main>
        <section id="donate">
            <h1>Support Our Team ❤️</h1>
            <p class="subtitle">Circuit Surfers is a student-run team operating independently without school funding. Every donation directly supports our team by covering competition registration fees, robot parts, and travel expenses. Your contribution helps us continue competing, learning, and representing our team on the robotics stage. No amount is too small — we appreciate every bit of support from our community!</p>

            <h2>How Your Money is Used 🤔</h2>
            <p class="subtitle">Here is how your money will be used to keep our team competing and growing:</p>

            <div class="cards">
                <div class="card">
                    <div class="icon">🏆</div>
                    <h3>Competition Registration</h3>
                    <p>Entry fees for league tournaments, regional championships, and state competitions.</p>
                </div>
                <div class="card">
                    <div class="icon">🤖</div>
                    <h3>Robot Parts</h3>
                    <p>VEX V5 motors, sensors, aluminum structure, and electronic components to build and maintain our competition robot.</p>
                </div>
                <div class="card">
                    <div class="icon">🛠️</div>
                    <h3>Tools & Equipment</h3>
                    <p>Specialized tools, safety equipment, and workspace improvements.</p>
                </div>
                <div class="card">
                    <div class="icon">✈️</div>
                    <h3>Travel Expenses</h3>
                    <p>Travel expenses for out-of-state tournaments.</p>
                </div>
            </div>

            <div class="page">
                <h2>Make a Donation 🏦</h2>
                <p class="subtitle">Your donation helps Circuit Surfers continue competing and inspiring the next generation of engineers — every contribution counts!</p>
                <div class="btn-wrapper">
                    <a class="donate-btn">Donate via Stripe</a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    main {
        padding-top: 95px;
        margin: 0;
    }

    #donate {
        padding: 4rem 2rem;
        max-width: 1100px;
        margin: 2rem auto;
        text-align: center;
    }

    .subtitle {
        color: var(--rgb-text-gray);
        max-width: 900px;
        margin: 1rem auto 3rem auto;
        line-height: 1.8;
    }

    h2 {
        margin-top: 3rem;
    }

    .cards {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        justify-content: center;
        margin-top: 2rem;
    }

    .card {
        background-color: var(--rgb-code-bg);
        border: 1px solid var(--rgb-accent-from);
        border-radius: 16px;
        padding: 2rem;
        width: 220px;
        text-align: center;
        transition: transform 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px); /* fixed typo: trasnlateY */
    }

    .icon {
        font-size: 1.5rem;
        background-color: var(--rgb-accent-to);
        border-radius: 50%;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem auto;
    }

    .card h3 {
        font-size: 1rem;
        margin: 0.5rem 0;
    }

    .page {
        margin-top: 4rem;
        border: 2px solid var(--rgb-accent-from);
        background: var(--rgb-code-bg);
        border-radius: 16px;
        padding: 2rem;
    }

    .btn-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
    }

    .donate-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        background: linear-gradient(135deg, var(--rgb-accent-from), var(--rgb-accent-to));
        color: white;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.2rem;
        padding: 1.2rem 4rem;
        border-radius: 12px;
        border: none;
        box-shadow: 0 4px 15px rgba(56, 182, 255, 0.4);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        width: 300px;
    }

    .donate-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(56, 182, 255, 0.6);
        color: white;
        cursor: pointer;
    }
</style>